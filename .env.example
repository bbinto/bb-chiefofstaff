# ==========================================
# LLM Configuration - Choose ONE:
# ==========================================

# Option 1: Use Anthropic Claude API (recommended for best quality)
ANTHROPIC_API_KEY=your_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Anthropic Admin API Key (optional) - for Usage & Cost API; shows period spend in report viewer.
# Create at console.anthropic.com → Admin API keys.
# ANTHROPIC_ADMIN_API_KEY=sk-ant-admin-...

# Option 2: Use Ollama (local or cloud)
# See OLLAMA_SETUP.md for complete setup instructions
# USE_OLLAMA=false
# OLLAMA_MODEL=mistral
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=                        # Leave empty for local; required for cloud providers (Groq, Together.ai, OpenRouter, etc.)

# Frontend Password Protection (optional)
# If set, users will need to enter this password to access the frontend
# Leave empty or remove this line to disable password protection
APP_PASSWORD=your_secure_password_here

VITE_API_URL=http://10.88.xxx.2:300

# MCP Server Configuration (path to your Claude Desktop MCP config)
MCP_CONFIG_PATH=/Users/yourusername/Library/Application Support/Claude/claude_desktop_config.json
